{
  "name": "spotit-production-app",
  "version": "0.1.0",
  "private": true,
  "description": "Secure production starter for the Spotit wound-care app.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "deploy:migrate": "prisma migrate deploy",
    "railway:predeploy": "node dist/scripts/railway-predeploy.js",
    "admin:create": "node dist/scripts/create-admin.js",
    "admin:create:dev": "tsx src/scripts/create-admin.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "argon2": "^0.40.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "prisma": "^5.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
